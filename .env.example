# ──────────────────────────────────────────────────────────────────────────────
# junggi-consulting 환경변수 템플릿 (.env.example)
# 실 사용 시 이 파일을 ".env"로 복사 후 값 입력
# .env 는 .gitignore 에 등록되어 있어야 함 (보안)
# ──────────────────────────────────────────────────────────────────────────────

# ── 한국은행 ECOS API ──────────────────────────────────────────────────────────
# 발급: https://ecos.bok.or.kr → 개발자센터 → API KEY 신청
ECOS_API_KEY=your_ecos_api_key_here

# ── DART 금융감독원 공시 API ─────────────────────────────────────────────────
# 발급: https://opendart.fss.or.kr → API 신청
DART_API_KEY=your_dart_api_key_here

# ── 국가법령정보센터 Open API ─────────────────────────────────────────────────
# 발급: https://open.law.go.kr → 오픈API 신청
LAW_API_ID=your_law_api_id_here

# ── 공공데이터포털 API ────────────────────────────────────────────────────────
# 발급: https://data.go.kr → 마이페이지 → 인증키 발급
PUBLIC_DATA_API_KEY=your_public_data_api_key_here

# ── 카카오 비즈메시지 (알림톡) ───────────────────────────────────────────────
# 발급: https://business.kakao.com → 카카오비즈 → 알림톡 채널 등록
KAKAO_BIZ_API_KEY=your_kakao_biz_api_key_here
KAKAO_SENDER_KEY=your_kakao_sender_key_here
KAKAO_TEMPLATE_CODE=your_kakao_template_code_here

# ── 국세청 Hometax 자동조회 ──────────────────────────────────────────────────
# 인증 방식 선택: cert (공동인증서) | simple (간편인증) | token (API 토큰)
HOMETAX_AUTH_TYPE=cert
# 공동인증서 방식 선택 시:
HOMETAX_CERT_PATH=C:\Users\username\NPKI\...
HOMETAX_CERT_PASSWORD=your_cert_password_here

# ── Gmail OAuth 2.0 ──────────────────────────────────────────────────────────
# 발급: Google Cloud Console → API·서비스 → 자격증명 → OAuth 2.0 클라이언트 ID
# 다운로드한 credentials.json 파일 절대경로 입력
GMAIL_CREDENTIALS_JSON=C:\path\to\credentials.json
